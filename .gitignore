# =============================================================================
# Nifty100 Financial Intelligence Platform — .gitignore
# Merged: project-specific (HEAD) + GitHub Python template (origin/main)
# =============================================================================

# ── Python: Byte-compiled / optimized / DLL files ────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so

# ── Python: Distribution / packaging ─────────────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── PyInstaller ───────────────────────────────────────────────────────────────
*.manifest
*.spec

# ── Installer logs ────────────────────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Unit test / coverage reports ─────────────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ── Translations ──────────────────────────────────────────────────────────────
*.mo
*.pot

# ── Jupyter Notebook ──────────────────────────────────────────────────────────
.ipynb_checkpoints
notebooks/*.ipynb

# ── IPython ───────────────────────────────────────────────────────────────────
profile_default/
ipython_config.py

# ── Virtual Environments ──────────────────────────────────────────────────────
.env
.envrc
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Package managers (lock files — keep in VCS for apps) ─────────────────────
# Pipfile.lock
# uv.lock
# poetry.lock
# poetry.toml
# pdm.lock
# pdm.toml
.pdm-python
.pdm-build/
.pixi

# ── PEP 582 ───────────────────────────────────────────────────────────────────
__pypackages__/

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Linters / formatters ──────────────────────────────────────────────────────
.ruff_cache/

# ── Cython debug symbols ──────────────────────────────────────────────────────
cython_debug/

# ── Documentation ─────────────────────────────────────────────────────────────
docs/_build/
/site

# ── Spyder / Rope ─────────────────────────────────────────────────────────────
.spyderproject
.spyproject
.ropeproject

# ── Abstra ────────────────────────────────────────────────────────────────────
.abstra/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Marimo ────────────────────────────────────────────────────────────────────
marimo/_static/
marimo/_lsp/
__marimo__/

# ── PyPI configuration ────────────────────────────────────────────────────────
.pypirc

# ── Misc Python tools ─────────────────────────────────────────────────────────
tempCodeRunnerFile.py

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
db.sqlite3
db.sqlite3-journal

# ── Project: Data Files (raw data stays local, not in VCS) ───────────────────
data/raw/*
data/processed/*
data/db/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/db/.gitkeep
!data/db/nifty100.db
!data/processed/mutual_funds.csv

# ── Project: Output & Reports ─────────────────────────────────────────────────
output/*
!output/.gitkeep
!output/pros_cons_generated.csv
!output/cluster_labels.csv
